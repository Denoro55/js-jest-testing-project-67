{
    "name": "@hexlet/code",
    "version": "1.0.0",
    "description": "",
    "bin": {
        "page-loader": "dist/cjs/cli.js"
    },
    "main": "dist/cjs/index.js",
    "types": "dist/cjs/index.d.ts",
    "type": "module",
    "engines": {
        "node": "22.22.1"
    },
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        }
    },
    "scripts": {
        "prepare": "npm run build",
        "test": "jest --colors --runInBand --bail",
        "prettier": "prettier --write .",
        "page-loader": "tsx src/cli.ts",
        "build": "tsc && tsc -p tsconfig.esm.json && echo '{\"type\":\"module\"}' > dist/esm/package.json && shx chmod +x dist/cjs/cli.js",
        "clean": "rm -rf output",
        "remove": "npm uninstall -g @hexlet/code"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/node": "^7.29.0",
        "@babel/preset-env": "^7.29.2",
        "@babel/preset-typescript": "^7.28.5",
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/debug": "^4.1.13",
        "@types/jest": "^29.5.14",
        "@types/moxios": "^0.4.17",
        "@types/node": "^25.5.0",
        "babel-jest": "^30.3.0",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.4.0",
        "jest": "^29.7.0",
        "moxios": "^0.4.0",
        "prettier": "^3.8.1",
        "shx": "^0.4.0",
        "tsx": "^4.21.0",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.57.0"
    },
    "dependencies": {
        "axios": "^1.13.6",
        "axios-debug-log": "^1.0.0",
        "cheerio": "^1.2.0",
        "commander": "^14.0.3",
        "debug": "^4.4.3",
        "npm": "^10.9.7"
    }
}
